{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/WasmAgent/agent-trust-infra/specs/agentbom/schema.json",
  "title": "AgentBOM",
  "description": "Agent Bill of Materials v0.1 — experimental draft",
  "type": "object",
  "required": ["agentbom_version", "identity", "attestation"],
  "properties": {
    "agentbom_version": { "type": "string", "enum": ["0.1"] },
    "identity": {
      "type": "object",
      "required": ["agent_id", "agent_name", "generated_at"],
      "properties": {
        "agent_id": { "type": "string" },
        "agent_name": { "type": "string" },
        "agent_version": { "type": "string" },
        "deployment_context": { "type": "string", "enum": ["development", "staging", "production"] },
        "generated_at": { "type": "string", "format": "date-time" }
      }
    },
    "model_layer": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "model_id": { "type": "string" },
        "model_version": { "type": "string" },
        "capabilities": { "type": "array", "items": { "type": "string" } }
      }
    },
    "tool_layer": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_id", "tool_name", "source"],
        "properties": {
          "tool_id": { "type": "string" },
          "tool_name": { "type": "string" },
          "source": { "type": "string", "enum": ["mcp", "builtin", "plugin"] },
          "mcp_server_id": { "type": "string" },
          "permissions": { "type": "array", "items": { "type": "string" } },
          "risk_signals": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "prompt_layer": {
      "type": "object",
      "properties": {
        "system_prompt_hash": { "type": "string" },
        "template_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "permission_layer": {
      "type": "object",
      "properties": {
        "granted_scopes": { "type": "array", "items": { "type": "string" } },
        "data_access": { "type": "array", "items": { "type": "string" } },
        "credential_references": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence_layer": {
      "type": "object",
      "properties": {
        "aep_references": { "type": "array", "items": { "type": "string" } },
        "evidence_hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "hash"],
            "properties": {
              "type": { "type": "string" },
              "hash": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    "risk_layer": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk_id", "severity", "category", "description", "status"],
        "properties": {
          "risk_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "mitigated", "accepted"] }
        }
      }
    },
    "attestation": {
      "type": "object",
      "required": ["generator"],
      "properties": {
        "generator": { "type": "string" },
        "generator_version": { "type": "string" },
        "agentbom_hash": { "type": "string" }
      }
    }
  }
}
