{
  "name": "@wasmagent/agent-trust-cli",
  "version": "0.0.0-research",
  "description": "CLI for Agent Trust Infrastructure — experimental research preview. AgentBOM generation, MCP Posture analysis, Trust Passport operations, and compliance checking.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "agent-trust": "./dist/index.js",
    "trust-cli": "./dist/index.js"
  },
  "files": ["dist/"],
  "keywords": [
    "agent-trust",
    "agentbom",
    "mcp-posture",
    "ai-trust",
    "trust-passport",
    "compliance",
    "cli",
    "mcp",
    "ai-agent",
    "security"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WasmAgent/agent-trust-infra",
    "directory": "cli"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@wasmagent/aep": "^1.8.0",
    "@wasmagent/agentbom-core": "workspace:*",
    "@wasmagent/mcp-posture-core": "workspace:*",
    "@wasmagent/trust-passport-core": "workspace:*"
  },
  "scripts": {
    "build": "mkdir -p dist && bun build ./src/index.ts --target node --outfile dist/index.js && sed -i '1s|#!/usr/bin/env bun|#!/usr/bin/env node|' dist/index.js",
    "prepack": "bun run build",
    "test": "bun test src/",
    "typecheck": "echo 'typecheck: stub'"
  }
}
